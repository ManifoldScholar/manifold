ignores: [
  # loaded by babel plugin name "@emotion" in vite.config.js
  "@emotion/babel-plugin",

  # browser polyfills of node packages
  # required to run Swagger UI
  "buffer",
  "stream-browserify",

  # required by API service for word ingestion
  "mammoth",

  # TODO might be OK to remove; check after swagger ui upgrade
  "swagger-ui-react",
]
skip-missing: true
