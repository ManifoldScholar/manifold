##########################################################################################
# Manifold Client Configuration
# For Docker Development Only
##########################################################################################

# The default domain that users access Manifold at.
DOMAIN=localhost

# In production, set this to "production".
NODE_ENV=development

# When enabled, the client SSR application will make secure requests to the API and
# generated URLs will prefer HTTPS. Used as a fallback when explicit URL vars aren't set.
SSL_ENABLED=false

# Allow self-signed certificates in development. Do not enable in production.
NODE_TLS_REJECT_UNAUTHORIZED=0

# The port the client SSR server listens on. During development with `yarn watch`,
# Manifold will also listen on port + 1 for SSR and port + 2 for the webpack dev server.
CLIENT_SERVER_PORT=13100

# The URL that the client application should be accessed at. Used by the client to set
# its own base URL. Falls back to DOMAIN if unset.
CLIENT_URL=http://localhost:13100

# The URL that the browser will use for the Manifold API. This variable is written to
# dist/manifold/www/browser.config.js when the browser bundle is built.
CLIENT_BROWSER_API_URL=http://localhost:13110

# The URL that the SSR node service will use to access the API. This may differ from
# CLIENT_BROWSER_API_URL when the API and SSR service communicate over an internal
# Docker network.
CLIENT_SERVER_API_URL=http://web:13110

# When not running a reverse proxy, the client proxies some paths to the API and to the
# browser build folder. Generally this should not be used in production.
CLIENT_SERVER_PROXIES=true

# Bind the webpack dev server to all interfaces so it's reachable within the Docker
# container. Node 22 defaults to IPv6 for "localhost", which causes proxy failures.
WEBPACK_DEV_HOST=0.0.0.0

# Enable filesystem polling for webpack watch. Required in Docker on macOS because
# native filesystem events don't propagate through bind mounts.
WEBPACK_WATCH_POLL=true
