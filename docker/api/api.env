##########################################################################################
# Manifold API Configuration
# For Docker Development Only
##########################################################################################

# The default domain that users access Manifold at. The client and the API will both use
# this variable when full URLs are generated, for example in emails sent by the API.
DOMAIN=localhost:13100

# The public-facing URL of the API. Used by the API to generate OAuth callback URLs,
# asset/upload URLs, EPUB packaging links, and route generation.
CLIENT_BROWSER_API_URL=http://localhost:13110

# Sets the default protocol (https vs http) for URL generation. Redundant when explicit
# URL vars like CLIENT_BROWSER_API_URL are set, but used as a fallback when they aren't.
SSL_ENABLED=false

# The port the API (Puma) listens on.
API_PORT=13110

# Disable the Spring application preloader.
DISABLE_SPRING=always

# In production, set this to "production".
RAILS_ENV=development

# Development only. Never use this value in production. Generate a unique key with
# `./bin/rails secret` for production deployments.
RAILS_SECRET_KEY=this-is-a-fake-development-secret-do-not-use-in-production

# Log to stdout so Docker can capture the output.
RAILS_LOG_TO_STD_OUT=TRUE

# Database connection strings. DATABASE_URL is the primary database, CACHE_DATABASE_URL
# is used by SolidCache.
DATABASE_URL="postgres://postgres:password@postgres/manifold_development"
CACHE_DATABASE_URL="postgres://postgres:password@postgres/manifold_cache_development"

# PG* vars are used by CLI tools (pg_dump, pg_isready, etc.) inside the container.
PGPORT=5432
PGHOST=postgres
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=manifold_development

# S3-compatible storage (MinIO in development).
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
UPLOAD_BUCKET=manifold-storage
